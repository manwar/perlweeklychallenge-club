%!PS

% begin included library code
% see https://codeberg.org/Firedrake/postscript-libraries/
/test {
    /test.count test.count 1 add def
    {
        /test.pass test.pass 1 add def
    } {
        ( ) print
        test.count (....) cvs print
        (-fail) print
    } ifelse
    count /test.stack2 exch def
    test.stack test.stack2 ne {
        print
        (Warning: stack deviation ) print
        test.stack2 test.stack sub print
        (\r\n) print
    } if
} bind def

/test.end {
    ( ) print
    test.count 0 gt {
        (Passed ) print
        test.pass (...) cvs print
        (/) print
        test.count (...) cvs print
        ( \() print
        test.pass 100 mul test.count idiv (...) cvs print
        (%\)) print
        (\r\n) print
    } if
} bind def

/a2s {
    2 dict begin
    /i exch def
    i length dup string /o exch def
    1 sub 0 exch 1 exch {
        dup i 3 -1 roll get o 3 1 roll put
    } for
    o
    end
} bind def

/test.start {
    print (:) print
    /test.pass 0 def
    /test.count 0 def
    count /test.stack exch def
} bind def


% end included library code

/largestsamedigitsnumber {
    0 dict begin
    /a exch def
    0
    a length -1 1 {
        /l exch def
        9 -1 1 {
            /n exch def
            /tst [
                l {
                    48 n add
                } repeat
            ] a2s def
            a tst search {
                pop pop pop
                pop tst cvi
                exit
            } {
                pop
            } ifelse
        } for
        dup 0 ne {
            exit
        } if
    } for
    end
} bind def

(largestsamedigitsnumber) test.start
(6777133339) largestsamedigitsnumber 3333 eq test
(1200034) largestsamedigitsnumber 4 eq test
(44221155) largestsamedigitsnumber 55 eq test
(88888) largestsamedigitsnumber 88888 eq test
(11122233) largestsamedigitsnumber 222 eq test
test.end
