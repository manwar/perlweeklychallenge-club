my @Test =
    # in                exp
    "6777133339",     3333,
    "1200034",           4,
    "44221155",         55,
    "88888",         88888,
    "11122233",        222,
￼
;

plan +@Test ÷ 2;

sub task( Str:D() $a where * ~~ /<[0..9]>+ / -->Int:D) {
    $s.comb.BagHash.pairs>>.&{ (.key x .value).Int }.max
}

for @Test -> $in, $exp {
    is task( $in), $exp, "{$exp // $exp.^name()} <- $in.raku()";
}
done-testing;

=finish

Input: $str = "6777133339"
Output: 3333
