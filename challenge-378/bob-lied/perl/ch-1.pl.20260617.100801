#!/usr/bin/env perl
# vim:set ts=4 sw=4 sts=4 et ai wm=0 nu:
#=============================================================================
# Copyright (c) 2026, Bob Lied
#=============================================================================
# ch-1.pl Perl Weekly Challenge 378 Task 1  Second Largest Digit
#=============================================================================
# You are given an alphanumeric string.  Write a script to find the second
# largest distinct digit in the given string. Return -1 if none found.
# 
# Example 1 Input: $str = "aaaaa77777" Output: -1
# Example 2 Input: $str = "abcde" Output: -1
# Example 3 Input: $str = "9zero8eight7seven9" Output: 8
# Example 4 Input: $str = "xyz9876543210" Output: 8
# Example 5 Input: $str = "4abc4def2ghi8jkl2" Output: 4
#=============================================================================

use v5.42;


use Getopt::Long;
my $Verbose = false;
my $DoTest  = false;
my $Benchmark = 0;

GetOptions("test" => \$DoTest, "verbose" => \$Verbose, "benchmark:i" => \$Benchmark);
my $logger;
{
    use Log::Log4perl qw(:easy);
    Log::Log4perl->easy_init({ level => ($Verbose ? $DEBUG : $INFO ),
            layout => "%d{HH:mm:ss.SSS} %p{1} %m%n" });
    $logger = Log::Log4perl->get_logger();
}
#=============================================================================

exit(!runTest()) if $DoTest;
exit( runBenchmark($Benchmark) ) if $Benchmark;

say task($_) for @ARGV;

#=============================================================================
sub task2($str)
{
    use List::MoreUtils qw/uniq/;

    return (uniq sort { $b <=> $a } grep /(\d)/, $str)[1] // -1;
}

sub task($str)
{
    $str =~ s/[^\d]+//g;
    my @large = (-1, -1);

    for ( split(//, $str) )
    {
        next if ( $_ == $large[0] || $_ == $large[1] );
        if ( $_ > $large[0] )
        {
            @large = ($_, $large[0]);
        }
        elsif ( $_ > $large[1] )
        {
            $large[1] = $_;
        }
    }
    return $large[1];
}

sub runTest
{
    use Test2::V1 -ipP;

    is( task("aaaaa77777"),          -1, "Example 1");
    is( task("abcde"),               -1, "Example 2");
    is( task("9zero8eight7seven9"),   8, "Example 3");
    is( task("xyz9876543210"),        8, "Example 4");
    is( task("4abc4def2ghi8jkl2"),    4, "Example 5");

    done_testing;
}

sub runBenchmark($repeat)
{
    use Benchmark qw/cmpthese/;

    cmpthese($repeat, {
            oneliner => sub { task2("9zero8one7two6three5four") },
            onepass  => sub {  task("9zero8one7two6three5four") },
        });
}

