{
  "challenge": {
    "week": 382,
    "task": 2,
    "name": "Replace Question Mark"
  },
  "input_vars": [ "$str" ],
  "examples": [
    {
      "name": "Example 1",
      "in": ["01??0"],
      "out": ["01000", "01010", "01100", "01110"]
    },
    {
      "name": "Example 2",
      "in": ["101"],
      "out": ["101"]
    },
    {
      "name": "Example 3",
      "in": ["???"],
      "out": ["000", "001", "010", "011", "100", "101", "110", "111"]
    },
    {
      "name": "Example 4",
      "in": ["1?10"],
      "out": ["1010", "1110"]
    },
    {
      "name": "Example 5",
      "in": ["1?1?0"],
      "out": ["10100", "10110", "11100", "11110"]
    }
  ]
}
